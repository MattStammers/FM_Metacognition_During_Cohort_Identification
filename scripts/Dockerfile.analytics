# syntax=docker/dockerfile:1.6
#
# Containerised analytics runner for the LLM metacognition study.
#
# This image bundles Python 3.12 and the ``analytics_code`` package so
# the entire pipeline (data prep, full performance, dropout, narrative,
# missingness threshold + both patient-level and document-level passes)
# can be reproduced on any machine that has Docker, regardless of
# host OS, OneDrive sync issues, or MAX_PATH limits.
#
# Build (run from repo root):
#   docker build -f scripts/Dockerfile.analytics -t llm-metacognition-analytics .
#
# Run:
#   docker run --rm -v "$PWD:/workspace" llm-metacognition-analytics
#
# Or use the docker-compose wrapper:
#   docker compose -f scripts/docker-compose.analytics.yml run --rm analytics

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    MPLBACKEND=Agg

WORKDIR /workspace

# Install build dependencies needed by pyarrow / scipy / matplotlib
# wheels on slim base images. ``--no-install-recommends`` keeps the
# image lean.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        build-essential \
        libfreetype6 \
        libpng16-16 \
 && rm -rf /var/lib/apt/lists/*

# Install python dependencies first so they cache independently of the
# source tree. We copy only the requirements + package metadata.
COPY analytics_code/requirements.txt /tmp/requirements.txt
RUN pip install --upgrade pip \
 && pip install -r /tmp/requirements.txt

# Copy the analytics package and install it in editable mode against
# the in-image source. Bind-mounting the workspace at runtime then
# transparently overlays user edits.
COPY analytics_code /opt/analytics_code
RUN sed -i 's/\r$//' /opt/analytics_code/docker_entrypoint.sh \
 && chmod +x /opt/analytics_code/docker_entrypoint.sh \
 && pip install -e /opt/analytics_code

# Default entrypoint runs the same default suite as the native wrapper:
# patient-level, document-level, complete-marker sensitivity, and
# validation-view endpoint passes against the bundled dummy config.
# Override with any other arguments (e.g. ``--config
# /workspace/analytics_code/configs/my_config.json``) at ``docker run`` time.
ENTRYPOINT ["/opt/analytics_code/docker_entrypoint.sh"]
CMD []
