{
  "general": {
    "batch_size": 100,
    "version": "v1",
    "output_dir": "./outputs/chronology_runs",
    "max_parallel_runners": 4,
    "max_retries": 3,
    "retry_delay_seconds": 0.25,
    "token_limit": 4000,
    "tokenizer_encoding": "cl100k_base",
    "save_format": "xlsx"
  },
  "runner_endpoints": {
    "mixtral_runner": {
      "enabled": true,
      "display_name": "mixtral_7b_t075",
      "url": "http://127.0.0.1:9001",
      "gpu_allocation": "GPU 0"
    },
    "m42_runner": {
      "enabled": true,
      "display_name": "m42_8b_t075",
      "url": "http://127.0.0.1:9002",
      "gpu_allocation": "GPU 1"
    },
    "deepseek14_runner": {
      "enabled": true,
      "display_name": "deepseek_14b_t075",
      "url": "http://127.0.0.1:9003",
      "gpu_allocation": "GPU 2"
    },
    "deepseek32_runner": {
      "enabled": true,
      "display_name": "deepseek_32b_t060",
      "url": "http://127.0.0.1:9004",
      "gpu_allocation": "GPU 3"
    }
  },
  "data_sources": {
    "primary_reports": {
      "path": "./data/primary_reports.csv",
      "patient_id_column": "patient_id",
      "date_column": "primary_report_date",
      "text_column": "primary_report_text",
      "date_format": null,
      "label": "PRIMARY REPORT"
    },
    "secondary_reports": {
      "path": "./data/secondary_reports.csv",
      "patient_id_column": "patient_id",
      "date_column": "secondary_report_date",
      "text_column": "secondary_report_text",
      "date_format": null,
      "label": "SECONDARY REPORT"
    },
    "context_notes": {
      "path": "./data/context_notes.csv",
      "patient_id_column": "patient_id",
      "date_column": "note_date",
      "text_column": "note_text",
      "date_format": null,
      "preceding_label": "PRECEDING CONTEXT NOTE",
      "following_label": "FOLLOWING CONTEXT NOTE"
    }
  },
  "matching": {
    "max_days_between_primary_and_secondary": 2
  },
  "prompt_templates": {
    "zero": "./prompt_templates/zero_shot.txt",
    "single": "./prompt_templates/single_shot.txt",
    "dual": "./prompt_templates/dual_shot.txt"
  },
  "report_sequences": {
    "primary_only": ["PRIMARY REPORT"],
    "secondary_only": ["SECONDARY REPORT"],
    "context_preceding": ["PRECEDING CONTEXT NOTE"],
    "context_following": ["FOLLOWING CONTEXT NOTE"],
    "primary_secondary": ["PRIMARY REPORT", "SECONDARY REPORT"],
    "secondary_primary": ["SECONDARY REPORT", "PRIMARY REPORT"],
    "context_both": ["PRECEDING CONTEXT NOTE", "FOLLOWING CONTEXT NOTE"],
    "context_primary_secondary": ["CONTEXT NOTE", "PRIMARY REPORT", "SECONDARY REPORT"],
    "primary_secondary_context": ["PRIMARY REPORT", "SECONDARY REPORT", "CONTEXT NOTE"],
    "all_docs_in_sequence": ["PRECEDING CONTEXT NOTE", "PRIMARY REPORT", "SECONDARY REPORT", "FOLLOWING CONTEXT NOTE"],
    "all_docs_in_reverse_sequence": ["FOLLOWING CONTEXT NOTE", "SECONDARY REPORT", "PRIMARY REPORT", "PRECEDING CONTEXT NOTE"],
    "jumbled": ["FOLLOWING CONTEXT NOTE", "PRIMARY REPORT", "PRECEDING CONTEXT NOTE", "SECONDARY REPORT"]
  }
}
